---
import Base from '../layouts/Base.astro';
---

<Base title="Maciek — Portfolio">
  <main>
    <section class="hero">
      <h1>Hi, I'm Maciek</h1>
      <p>Welcome to my portfolio. This page is served from a ThinkPad T430 in my living room.</p>
    </section>

    <section class="projects">
      <h2>Projects</h2>
      <div class="grid">
        <article class="card">
          <h3>Project One</h3>
          <p>Description of your first project.</p>
          <a href="#">View project &rarr;</a>
        </article>
        <article class="card">
          <h3>Project Two</h3>
          <p>Description of your second project.</p>
          <a href="#">View project &rarr;</a>
        </article>
      </div>
    </section>
  </main>
</Base>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .hero {
    margin-bottom: 4rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.2rem;
    color: #555;
  }

  .projects h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .card h3 {
    margin-bottom: 0.5rem;
  }

  .card p {
    color: #555;
    margin-bottom: 1rem;
  }
</style>
